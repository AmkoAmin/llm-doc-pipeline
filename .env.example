# Chat LLM provider: "anthropic" (default) or "openai".
# The embedding model is independent of this choice.
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6
# Only needed when LLM_PROVIDER=openai
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o
VOYAGE_API_KEY=pa-...
EMBEDDING_MODEL=voyage-3.5
VECTOR_STORE_PATH=data/faiss_index
CORS_ORIGINS=https://aminskenderi.me,https://www.aminskenderi.me
RATE_LIMIT_PER_MINUTE=10
